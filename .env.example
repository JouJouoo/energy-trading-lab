# OpenAI-compatible LLM settings for Energy Trading Lab.
# Copy to .env or export these variables in your shell before starting the server.

ENERGY_LAB_LLM_API_KEY=your_api_key_here
ENERGY_LAB_LLM_BASE_URL=https://api.openai.com/v1
ENERGY_LAB_LLM_MODEL=gpt-4o-mini
ENERGY_LAB_LLM_TIMEOUT=30
ENERGY_LAB_LLM_TEMPERATURE=0.1
ENERGY_LAB_LLM_MAX_TOKENS=2500

# Set to true to force deterministic fallback mode.
ENERGY_LAB_LLM_DISABLED=false
