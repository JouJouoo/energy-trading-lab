# Container host port mapping
ENERGY_LAB_PORT=8765

# LLM (BYOK) — leave blank to use deterministic fallback
ENERGY_LAB_LLM_PROVIDER=openai
ENERGY_LAB_LLM_API_KEY=
ENERGY_LAB_LLM_BASE_URL=https://api.openai.com/v1
ENERGY_LAB_LLM_MODEL=gpt-4o-mini
ENERGY_LAB_LLM_TIMEOUT=30
ENERGY_LAB_LLM_TEMPERATURE=0.1

# Bind mount points (relative to deploy/ on the host)
DATA_DIR=./data
RUNS_DIR=./runs
